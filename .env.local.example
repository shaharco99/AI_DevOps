# .env.local.example
# Copy this to .env.local and fill in your actual local development secrets
# WARNING: .env.local is gitignored and should NEVER be committed
#
# To use:
# 1. cp .env.local.example .env.local
# 2. Fill in your actual credentials
# 3. DO NOT commit .env.local to git

# ============================================================================
# Application Secrets (Generate a strong key for local dev)
# ============================================================================
# Generate with: python -c \"import secrets; print(secrets.token_urlsafe(32))\"
SECRET_KEY=your-local-development-secret-key

# ============================================================================
# Database
# ============================================================================
# Local PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://devops_user:devops_password@localhost:5432/devops

# ============================================================================
# CI/CD Provider Credentials
# ============================================================================

# Azure DevOps
# 1. Get your Organization from https://dev.azure.com
# 2. Get your Project name
# 3. Create a Personal Access Token: https://dev.azure.com/_usersSettings/tokens
AZURE_DEVOPS_URL=https://dev.azure.com
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_PAT=your-azure-devops-personal-access-token

# Jenkins
# 1. Create a username and API token in Jenkins: http://jenkins:8080/user/admin/configure
# 2. API token is generated like a password (use this instead of actual password)
JENKINS_URL=http://localhost:8080
JENKINS_USER=your-jenkins-username
JENKINS_API_TOKEN=your-jenkins-api-token

# GitHub
# 1. Create a Personal Access Token: https://github.com/settings/tokens
# 2. Scopes needed: repo, workflow (for GitHub Actions)
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repository-name
GITHUB_TOKEN=your-github-personal-access-token

# ============================================================================
# Optional: Local Service URLs
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
PROMETHEUS_URL=http://localhost:9090
CHROMA_PERSIST_DIR=/tmp/chroma
