# ============================================================================
# AI DevOps Assistant - Environment Configuration Template
# Copy to .env and configure for your environment
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME="AI DevOps Assistant"
APP_VERSION="0.1.0"
API_HOST="0.0.0.0"
API_PORT=8000
API_LOG_LEVEL="INFO"
API_ENVIRONMENT="development"
SECRET_KEY="your-secret-key-change-this-in-production"
ALLOWED_HOSTS="localhost,127.0.0.1"

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql+asyncpg://devops_user:devops_password@localhost:5432/devops
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false
DATABASE_SSL_MODE="disable"

# ============================================================================
# LLM Configuration (Ollama Primary)
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# ============================================================================
# Multi-LLM Support
# ============================================================================
LLM_PROVIDER="ollama"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-sonnet-20240229"
HUGGINGFACE_API_KEY=""
HUGGINGFACE_MODEL="meta-llama/Llama-2-7b"

# ============================================================================
# Vector Database Configuration
# ============================================================================
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_ANONYMIZED_TELEMETRY=false
MAX_RAG_DOCUMENTS=1000

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
EMBEDDING_MODEL="nomic-embed-text"

# ============================================================================
# Kubernetes Configuration
# ============================================================================
KUBECONFIG=""
K8S_NAMESPACE=default
K8S_VERIFY_SSL=true
K8S_TIMEOUT=30

# ============================================================================
# Prometheus Configuration
# ============================================================================
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=10

# ============================================================================
# FastAPI Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
API_ENVIRONMENT=development

# ============================================================================
# CI/CD Pipeline Settings
# ============================================================================
AZURE_DEVOPS_URL="https://dev.azure.com"
AZURE_DEVOPS_ORG=""
AZURE_DEVOPS_PROJECT=""
AZURE_DEVOPS_PAT=""
JENKINS_URL="http://localhost:8080"
JENKINS_USER=""
JENKINS_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO=""
GITHUB_TOKEN=""

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_RAG=true
ENABLE_K8S_TOOL=true
ENABLE_SQL_TOOL=true
ENABLE_METRICS_TOOL=true
ENABLE_LOG_TOOL=true
ENABLE_PIPELINE_TOOL=true
ENABLE_SCRAPING_TOOL=true

# ============================================================================
# Logging Settings
# ============================================================================
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# ============================================================================
# Security Settings
# ============================================================================
ENABLE_SAST=true
ENABLE_DEPENDENCY_SCAN=true
ENABLE_CONTAINER_SCAN=true

# ============================================================================
# Fine-Tuning Settings
# ============================================================================
FINETUNING_ENABLED=false
FINETUNING_LEARNING_RATE=2e-5
FINETUNING_NUM_EPOCHS=3
FINETUNING_BATCH_SIZE=8
FINETUNING_OUTPUT_DIR="./finetuned_models"

# ============================================================================
# Model Registry Settings
# ============================================================================
HUGGINGFACE_REGISTRY_ENABLED=true
OLLAMA_REGISTRY_ENABLED=true

# ============================================================================
# Web Scraping Settings
# ============================================================================
SCRAPING_USER_AGENT="AI-DevOps-Assistant/1.0"
SCRAPING_TIMEOUT=30
SCRAPING_MAX_WORKERS=5
SCRAPING_ENABLE_JAVASCRIPT=false
EMBEDDING_MODEL=nomic-embed-text
MAX_RAG_DOCUMENTS=1000

# ============================================================================
# Security & Secrets
# IMPORTANT: Never commit real secrets to version control!
# Use environment variables, .env.local (gitignored), or secret management systems
# See SECRETS_MANAGEMENT.md for best practices
# ============================================================================
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# CI/CD Provider Secrets (Keep these in .env.local or secret manager)
# ============================================================================
# Azure DevOps
AZURE_DEVOPS_URL=https://dev.azure.com
AZURE_DEVOPS_ORG=your-organization
AZURE_DEVOPS_PROJECT=your-project
# AZURE_DEVOPS_PAT=<use external secret manager>

# Jenkins
JENKINS_URL=http://jenkins:8080
JENKINS_USER=your-jenkins-username
# JENKINS_API_TOKEN=<use external secret manager>

# GitHub
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name
# GITHUB_TOKEN=<use external secret manager>

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_RAG=true
ENABLE_K8S_TOOL=true
ENABLE_SQL_TOOL=true
ENABLE_METRICS_TOOL=true
ENABLE_LOG_TOOL=true
ENABLE_PIPELINE_TOOL=true
