# AI DevOps Configuration

# ============================================================================
# LLM Configuration
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql+asyncpg://devops_user:devops_password@localhost:5432/devops
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# ============================================================================
# Vector Database Configuration
# ============================================================================
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_ANONYMIZED_TELEMETRY=false

# ============================================================================
# Kubernetes Configuration
# ============================================================================
KUBECONFIG=/home/user/.kube/config
K8S_NAMESPACE=default
K8S_VERIFY_SSL=true

# ============================================================================
# Prometheus Configuration
# ============================================================================
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=10

# ============================================================================
# FastAPI Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
API_ENVIRONMENT=development

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
EMBEDDING_MODEL=nomic-embed-text
MAX_RAG_DOCUMENTS=1000

# ============================================================================
# Security & Secrets
# ============================================================================
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_RAG=true
ENABLE_K8S_TOOL=true
ENABLE_SQL_TOOL=true
ENABLE_METRICS_TOOL=true
ENABLE_LOG_TOOL=true
